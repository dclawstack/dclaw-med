# DClaw Med Environment Variables
# Copy this file to .env and fill in the values

# Database
DB_PASSWORD=change-me-in-production
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/dclaw_med

# AI Providers
OPENROUTER_API_KEY=          # Required for cloud models
OPENROUTER_URL=https://openrouter.ai/api/v1

# Auth (Logto) — leave empty if not using SSO
LOGTO_ENDPOINT=
LOGTO_AUDIENCE=

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8092/api
CORS_ORIGINS=http://localhost:3004,http://localhost:3000
